# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/computeruse

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# Browserbase
BROWSERBASE_API_KEY=bb_xxx
BROWSERBASE_PROJECT_ID=proj_xxx

# Cloudflare R2
R2_ACCESS_KEY=xxx
R2_SECRET_KEY=xxx
R2_BUCKET_NAME=computeruse-recordings
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com

# AWS S3 (legacy replay storage, used by SDK)
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_BUCKET_NAME=computeruse-replays
AWS_REGION=us-east-1

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# 2Captcha
TWOCAPTCHA_API_KEY=xxx

# Security
API_SECRET_KEY=change-me-to-a-random-secret
ENCRYPTION_MASTER_KEY=change-me-to-a-32-byte-hex-key

# Execution defaults
DEFAULT_MODEL=claude-sonnet-4-5
DEFAULT_TIMEOUT=300
DEFAULT_MAX_STEPS=50

# Storage directories (SDK local mode)
SESSION_DIR=./sessions
REPLAY_DIR=./replays
