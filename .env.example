# ─────────────────────────────────────────────────────────────────────────────
# Observius — environment variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# REQUIRED for local SDK use (python demo.py, examples/):
#   ANTHROPIC_API_KEY
#
# OPTIONAL — only needed when running specific features:
#   BROWSERBASE_*     cloud browser sessions (ComputerUse(local=False))
#   SUPABASE_*        task history persistence
#   DATABASE_URL      same as Supabase — asyncpg DSN
#   REDIS_URL         Celery broker (workers only)
#   R2_* / AWS_*      replay upload to object storage
#   STRIPE_*          billing (dashboard + API)
#   ENCRYPTION_*      credential encryption (workers)
#   TWOCAPTCHA_*      captcha solving
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────

# Anthropic API key — get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional: cloud browser (needed for ComputerUse(local=False)) ─────────────

BROWSERBASE_API_KEY=your_browserbase_key_here_optional
BROWSERBASE_PROJECT_ID=your_browserbase_project_id_optional

# ── Optional: database (needed for task history + API server) ─────────────────

# Supabase project URL and anon/service key
SUPABASE_URL=your_supabase_url_here_optional
SUPABASE_KEY=your_supabase_key_here_optional

# Full asyncpg DSN (used by SQLAlchemy in the API server)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/observius

# ── Optional: queue (needed for Celery workers) ───────────────────────────────

REDIS_URL=redis://localhost:6379/0

# ── Optional: object storage (needed for replay uploads) ──────────────────────

# Cloudflare R2
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET_NAME=observius-replays
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# AWS S3 (legacy / alternative to R2)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_BUCKET_NAME=observius-replays
AWS_REGION=us-east-1

# ── Optional: billing (needed for Stripe integration) ────────────────────────

STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Optional: security (needed for API server + workers) ─────────────────────

API_SECRET_KEY=change-me-to-a-random-32-char-secret
ENCRYPTION_MASTER_KEY=change-me-to-a-64-char-hex-string

# ── Optional: captcha solving ─────────────────────────────────────────────────

TWOCAPTCHA_API_KEY=your_2captcha_key

# ── Dashboard (Next.js) ──────────────────────────────────────────────────────

# Browser-facing API URL — must be reachable from the host browser, NOT a Docker
# service name.  docker-compose.yml sets this automatically; override here only
# when running the dashboard outside Docker.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side API URL — used by Next.js server components / API routes inside
# Docker to reach the API container.  Set to http://api:8000 in docker-compose.
INTERNAL_API_URL=http://localhost:8000

# ── SDK defaults (override if needed) ────────────────────────────────────────

DEFAULT_MODEL=claude-sonnet-4-5
DEFAULT_TIMEOUT=300
DEFAULT_MAX_STEPS=50
SESSION_DIR=./sessions
REPLAY_DIR=./replays
