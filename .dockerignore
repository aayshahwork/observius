# Version control
.git/
.gitignore

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/
ENV/
.env/

# Build artifacts
build/
dist/
*.egg-info/
.eggs/

# Test artifacts
.pytest_cache/
.coverage
.mypy_cache/
htmlcov/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Environment files — never bake secrets into the image
.env
.env.*
!.env.example

# Runtime data — these are mounted as volumes at runtime
sessions/
replays/

# Node (if any frontend tooling is present)
node_modules/

# Documentation
docs/
*.md
!README.md

# CI
.github/

# Local dev scripts
Makefile
docker-compose.override.yml
